<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_inbox_premium">

    <!-- Ambient Glow -->
    <View
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:alpha="0.9"
        android:background="@drawable/bg_top_glow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="28dp"
        android:paddingEnd="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/silver"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Encrypted premium conversations"
            android:textColor="@color/silver_soft"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Search -->
    <LinearLayout
        android:id="@+id/searchContainer"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_search_premium"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerContainer">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_search"/>

        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:background="@android:color/transparent"
            android:hint="Search conversations"
            android:minHeight="48dp"
            android:textColor="@color/silver"
            android:textColorHint="@color/silver_soft"
            android:textSize="20sp" />

    </LinearLayout>

    <!-- Fancy Action Buttons -->
    <HorizontalScrollView
        android:id="@+id/actionsScroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/searchContainer">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="12dp">

            <!-- NEW -->
            <LinearLayout
                android:id="@+id/btnNew"
                android:layout_width="wrap_content"
                android:layout_height="58dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/bg_action_glass"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:minWidth="132dp"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_new"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="New"
                    android:textColor="@color/silver"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!--Notifications-->
            <LinearLayout
                android:id="@+id/btnNotifications"
                android:layout_width="wrap_content"
                android:layout_height="58dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/bg_action_glass"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:minWidth="170dp"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp">

                <FrameLayout
                    android:layout_width="25dp"
                    android:layout_height="22dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_notifications" />

                    <View
                        android:id="@+id/vNotificationsDot"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="top|end"
                        android:background="@drawable/bg_notifications_dot" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Notifications"
                    android:textColor="@color/silver"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- PRIORITIES -->
            <LinearLayout
                android:id="@+id/btnPriorities"
                android:layout_width="wrap_content"
                android:layout_height="58dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/bg_action_glass"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:minWidth="170dp"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_priority"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Priorities"
                    android:textColor="@color/silver"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- SETTINGS -->
            <LinearLayout
                android:id="@+id/btnSettings"
                android:layout_width="wrap_content"
                android:layout_height="58dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/bg_action_glass"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:minWidth="155dp"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_settings"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Settings"
                    android:textColor="@color/silver"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

            </LinearLayout>

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Chat List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="22dp"
        android:clipToPadding="false"
        android:paddingHorizontal="18dp"
        android:paddingBottom="120dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/actionsScroll" />

    <!-- Floating Button -->
    <FrameLayout
        android:layout_width="78dp"
        android:layout_height="78dp"
        android:layout_margin="24dp"
        android:background="@drawable/bg_fab_glow"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:layout_width="62dp"
            android:layout_height="62dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_fab_inner"
            android:src="@drawable/ic_edit"/>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>