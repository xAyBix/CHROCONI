<?xml version="1.0" encoding="utf-8"?>

<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Shadow -->
    <item android:top="3dp">

        <shape>
            <solid android:color="#18000000"/>
            <corners android:radius="24dp"/>
        </shape>

    </item>

    <!-- Glass -->
    <item>

        <shape>

            <gradient
                android:startColor="#22FF5C7A"
                android:centerColor="#18D94A66"
                android:endColor="#10B53B56"
                android:angle="270"/>

            <corners android:radius="24dp"/>

            <stroke
                android:width="1dp"
                android:color="#66FF5C7A"/>

        </shape>

    </item>

</layer-list>