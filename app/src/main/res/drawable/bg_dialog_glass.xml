<?xml version="1.0" encoding="utf-8"?>

<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Shadow -->
    <item android:top="4dp">

        <shape>

            <solid android:color="#D7000A17"/>

            <corners android:radius="34dp"/>

        </shape>

    </item>

    <!-- Glass -->
    <item>

        <shape>

            <gradient
                android:startColor="#24FFFFFF"
                android:centerColor="#1FFFFFFF"
                android:endColor="#08FFFFFF"
                android:angle="270"/>

            <corners android:radius="34dp"/>

            <stroke
                android:width="1dp"
                android:color="#40FFFFFF"/>

        </shape>

    </item>

</layer-list>