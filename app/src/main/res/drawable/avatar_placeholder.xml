<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background Circle -->
    <item>
        <shape android:shape="oval">

            <gradient
                android:startColor="#1E293B"
                android:centerColor="#334155"
                android:endColor="#0F172A"
                android:angle="315"/>

        </shape>
    </item>

    <!-- Inner Glow -->
    <item
        android:left="6dp"
        android:top="6dp"
        android:right="6dp"
        android:bottom="6dp">

        <shape android:shape="oval">

            <gradient
                android:startColor="#38BDF8"
                android:endColor="#2563EB"
                android:angle="45"/>

            <alpha android:alpha="40"/>

        </shape>

    </item>

</layer-list>