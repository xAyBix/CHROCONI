<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Soft Shadow -->
    <item android:top="3dp">
        <shape>
            <solid android:color="#12000000"/>
            <corners android:radius="30dp"/>
        </shape>
    </item>

    <!-- Main Glass Layer -->
    <item>
        <shape>

            <gradient
                android:startColor="#20FFFFFF"
                android:centerColor="#12FFFFFF"
                android:endColor="#08FFFFFF"
                android:angle="135"/>

            <corners android:radius="30dp"/>

            <stroke
                android:width="1dp"
                android:color="#40FFFFFF"/>

            <padding
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="2dp"/>

        </shape>
    </item>

</layer-list>