<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Glow Shadow -->
    <item>
        <shape>
            <gradient
                android:startColor="#6638BDF8"
                android:endColor="#002563EB"
                android:angle="90"/>

            <corners android:radius="24dp"/>
        </shape>
    </item>

    <!-- Main Button -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">

        <shape>

            <gradient
                android:startColor="#38BDF8"
                android:centerColor="#3B82F6"
                android:endColor="#2563EB"
                android:angle="45"/>

            <corners android:radius="22dp"/>

            <stroke
                android:width="1dp"
                android:color="#66FFFFFF"/>

        </shape>

    </item>

</layer-list>