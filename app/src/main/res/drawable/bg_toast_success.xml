<?xml version="1.0" encoding="utf-8"?>

<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Shadow -->
    <item android:top="3dp">

        <shape>
            <solid android:color="#18000000"/>
            <corners android:radius="24dp"/>
        </shape>

    </item>

    <!-- Glass -->
    <item>

        <shape>

            <gradient
                android:startColor="#2230D158"
                android:centerColor="#1827AE4D"
                android:endColor="#10209341"
                android:angle="270"/>

            <corners android:radius="24dp"/>

            <stroke
                android:width="1dp"
                android:color="#5530D158"/>

        </shape>

    </item>

</layer-list>