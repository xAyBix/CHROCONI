<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer soft glow -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="340dp"
                android:startColor="#5538BDF8"
                android:centerColor="#1A38BDF8"
                android:endColor="#0038BDF8"/>
        </shape>
    </item>

    <!-- Inner glow -->
    <item
        android:left="40dp"
        android:top="40dp"
        android:right="40dp"
        android:bottom="40dp">

        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="220dp"
                android:startColor="#887DD3FC"
                android:centerColor="#3338BDF8"
                android:endColor="#0038BDF8"/>
        </shape>

    </item>

</layer-list>